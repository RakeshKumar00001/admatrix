# ─── Database ───────────────────────────────────────────
DATABASE_URL="postgresql://saas_user:saas_pass@localhost:5432/saas_db"

# ─── JWT ─────────────────────────────────────────────────
JWT_SECRET="change-this-to-a-64-char-random-secret"
JWT_EXPIRES_IN="7d"
JWT_REFRESH_SECRET="change-this-to-another-64-char-secret"
JWT_REFRESH_EXPIRES_IN="30d"

# ─── Encryption (AES-256 for token storage) ───────────────
ENCRYPTION_KEY="32-char-random-hex-key-here!!!!!"

# ─── Server ───────────────────────────────────────────────
PORT=4000
NODE_ENV=development
CORS_ORIGINS="http://localhost:5173"

# ─── Meta / Facebook API ─────────────────────────────────
META_APP_ID="your_meta_app_id"
META_APP_SECRET="your_meta_app_secret"
META_SYSTEM_USER_TOKEN="your_system_user_long_lived_token"
META_API_VERSION="v19.0"

# ─── Email (SendGrid) ────────────────────────────────────
SENDGRID_API_KEY="SG.xxxxxxxxxxxx"
EMAIL_FROM="reports@youragency.com"
EMAIL_FROM_NAME="Your Agency Name"

# ─── Frontend URL (for PDF/email links) ──────────────────
FRONTEND_URL="http://localhost:5173"

# ─── Cron Jobs ───────────────────────────────────────────
CRON_DAILY_SYNC="0 2 * * *"
CRON_WEEKLY_REPORT="0 8 * * 1"

# ─── Feature Flags ───────────────────────────────────────
USE_MOCK_DATA=true
ENABLE_EMAIL_REPORTS=false
ENABLE_AI_INSIGHTS=false
OPENAI_API_KEY=""
